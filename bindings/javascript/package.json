{
  "name": "@mitchell/javascript",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript bindings for Mitchell zarr stores",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/node.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.test.json"
  },
  "dependencies": {
    "@zarrita/storage": "^0.1.4",
    "zarrita": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
